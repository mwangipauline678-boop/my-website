<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pamabra Electrical & Motor Rewinding | Industrial Excellence</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
</head>
<body>

    <nav class="navbar">
        <div class="container">
            <div class="logo-container">
                <img src="assets/images/logo.jpeg" alt="Pamabra Logo" class="nav-logo">
            </div>
            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#services">Services</a></li>
                <li><a href="#gallery">Gallery</a></li>
                <li><a href="#quote-section" class="nav-cta">Get Started</a></li>
            </ul>
        </div>
    </nav>

    <header id="home" class="hero">
        <div class="container">
            <div class="hero-content">
                <h1>Industrial Excellence <br><strong>For Lasting Success</strong></h1>
                <p>Expert electrical solutions and precision motor rewinding designed to empower your business growth and operational efficiency.</p>
                <div class="cta-btns">
                    <a href="#quote-section" class="btn btn-yellow">Get a Free Consultation</a>
                    <a href="#services" class="btn btn-blue-outline">Our Services</a>
                </div>
            </div>
        </div>
    </header>

    <section class="stats-bar">
        <div class="container">
            <div class="stat-item"><strong>15+</strong><p>Years Experience</p></div>
            <div class="stat-item"><strong>500+</strong><p>Motors Repaired</p></div>
            <div class="stat-item"><strong>24hr</strong><p>Response Time</p></div>
            <div class="stat-item"><strong>100%</strong><p>Quality Guarantee</p></div>
        </div>
    </section>

    <section id="services" class="services">
        <div class="container">
            <h2 class="section-title">Our Specialized Services</h2>
            <div class="services-grid">
                <div class="service-card">
                    <i class="fas fa-tools"></i>
                    <h3>Motor Rewinding</h3>
                    <p>Professional single & 3-phase rewinding with high-grade copper.</p>
                </div>
                <div class="service-card">
                    <i class="fas fa-bolt"></i>
                    <h3>Installation</h3>
                    <p>Industrial control panels and expert factory wiring solutions.</p>
                </div>
                <div class="service-card">
                    <i class="fas fa-video"></i>
                    <h3>CCTV Security</h3>
                    <p>Full HD surveillance with remote mobile monitoring via Hikvision.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="quote-section">
        <div class="container">
            <div class="quote-container">
                <div class="quote-text">
                    <h2>Partner With Us</h2>
                    <p>Let's discuss your next industrial project. Fill out the form and we'll be in touch shortly.</p>
                </div>
                <div class="quote-form-wrapper">
                    <form class="main-form">
                        <input type="text" placeholder="Your Name" required>
                        <input type="tel" placeholder="Phone Number" required>
                        <select required>
                            <option value="">Select Service</option>
                            <option value="motor">Motor Rewinding</option>
                            <option value="electrical">Electrical Installation</option>
                            <option value="cctv">CCTV Setup</option>
                        </select>
                        <textarea placeholder="Tell us about your project" rows="3"></textarea>
                        <button type="submit" class="btn btn-yellow btn-full">Submit Request</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <section id="gallery" class="gallery">
        <div class="container">
            <h2 class="section-title">Project Gallery</h2>
            <div class="gallery-grid">
                <div class="gallery-item"><img src="assets/images/1000680940.jpeg" alt="Project"></div>
                <div class="gallery-item"><img src="assets/images/1000680930.jpeg" alt="Project"></div>
                <div class="gallery-item"><img src="assets/images/1000680938.jpeg" alt="Project"></div>
                <div class="gallery-item"><img src="assets/images/1000680933.jpeg" alt="Project"></div>
            </div>
        </div>
    </section>

    <footer>
        <div class="container footer-grid">
            <div>
                <h3>Pamabra Electrical</h3>
                <p>Leading specialists in Thika and Kangema.</p>
            </div>
            <div>
                <h4>Contact</h4>
                <p>0790366315</p>
                <p>allankk247@gmail.com</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Pamabra Electrical. Site by Pauline.</p>
        </div>
    </footer>

</body>
</html>
